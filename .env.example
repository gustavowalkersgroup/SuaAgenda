# App
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/saas_atendimento
POSTGRES_DB=saas_atendimento
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-in-production

# Redis
REDIS_URL=redis://:your-redis-password@localhost:6379
REDIS_PASSWORD=change-me-in-production

# Evolution API (WhatsApp)
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=your-evolution-api-key

# OpenAI
OPENAI_API_KEY=sk-...

# Encryption (AES-256 para armazenar API keys dos tenants — 32 chars hex)
ENCRYPTION_KEY=32-char-hex-encryption-key-here!!

# Timezone
TZ=America/Sao_Paulo

# Frontend (prod)
NEXT_PUBLIC_API_URL=https://seudominio.com
