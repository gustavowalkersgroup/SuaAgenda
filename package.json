{
  "name": "saas-atendimento",
  "version": "1.0.0",
  "description": "SaaS multi-tenant atendimento + agenda para prestadores de serviço",
  "main": "dist/app.js",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
